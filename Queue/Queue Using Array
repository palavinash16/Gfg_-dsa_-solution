// queue usng array 


class myQueue {
    // here we can assign the variable 
   
  public:
    int rear;
    int front;
    
    vector<int> arr;
    myQueue(int n) {
        // Define Data Structures
        // here we can assign the variable 
        
        arr.resize(n);
        front=-1;
        rear=-1;
        
        
    }

    bool isEmpty() {
        // check if the queue is empty
        if(rear==-1) {
            return true;
        }else{
            return false;
        }
    }

    bool isFull() {
        // check if the queue is full
        if ((rear+1)%arr.size()==front){
            return true;
        }
        else{
            return false;
        }
    }

    void enqueue(int x) {
        // Adds an element x at the rear of the queue.
        
        
        if(rear==-1){ front = 0;}
        
            rear++;
            rear= rear%arr.size();
            arr[rear]=x;
            
        
    }

    void dequeue() {
        // Removes the front element of the queue.
        
        
        if(front==rear){
            front =-1;
            rear=-1;
        }
        else{
        front++;
        front=front%arr.size();
        }
    }

    int getFront() {
        // Returns the front element of the queue.
        if(front==-1) return -1;
        return arr[front];
    }

    int getRear() {
        // Return the last element of queue
        if(rear==-1) return -1;
        else  return arr[rear];
    }
};
